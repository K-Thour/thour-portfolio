# -----------------------------------------------------------------------------
# Portfolio Backend Environment Variables
# -----------------------------------------------------------------------------

# Server Configuration
PORT=3000

# Database Configuration
# MongoDB Connection URI (e.g., mongodb://localhost:27017/portfolio or mongodb+srv://...)
MONGO_URI=mongodb://localhost:27017/portfolio

# Authentication & Security Configurations
PASSWORD_PEPPER=thour
SALT_ROUNDS=10
JWT_SECRET=your_jwt_secret_key_here
TOKEN_EXPIRY=1d

# Admin Seed Account Configuration (Used to initialize/seed the database admin user)
SEED_EMAIL=admin@portfolio.com
SEED_PASSWORD=Password123!

# AI / LLM Configuration
# API Key for Google Gemini (required for AI portfolio optimization and content generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary Configuration (required for media uploads/image storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Mail Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=no-reply@portfolio.com
